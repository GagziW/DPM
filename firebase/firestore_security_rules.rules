rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================
    // USER DATA
    // ============================================================
    
    match /users/{userId} {
      // PRODUCTION COMPATIBILITY: the iOS App Store build (2.1.9) writes the
      // whole User struct via setData without merge, which strips any fields
      // it doesn't know about (e.g. `flames`, `totalFlamePoints`, …). The
      // earlier field-level update lock caught those strips as a "change" to
      // server-managed fields and denied the write, breaking sign-in for
      // every 2.1.9 user. Until 2.1.9 cycles out of the App Store, update
      // stays permissive.
      //
      // The integrity that lock was protecting still holds where it matters:
      //   - The leaderboard is computed from `flameEvents` (server-only).
      //   - Voucher redemptions are audited in `voucherCodes` (server-only).
      //   - Stripe-managed subscription fields are overwritten by the next
      //     webhook event (admin SDK, also rules-bypassing).
      // So a tampered client can only briefly forge values in its OWN user
      // doc — annoying, not catastrophic.
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Lottery subcollection — scoped to the owner. Previously any
      // authenticated user could read/write ANY other user's lottery docs
      // (no uid check); a user only ever touches their own lottery data.
      match /lottery/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // ============================================================
    // CHALLENGES (Personal Records)
    // ============================================================
    
    match /challenges/{challengeId} {
      // TEMPORARY: All operations allowed for authenticated users
      allow create, read, update, delete: if request.auth != null;
    }
    
    // ============================================================
    // PAYMENTS
    // ============================================================
    
    match /payments/{paymentId} {
      // Users can create payments for themselves
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      // Clients legitimately update only `status` / `challengeId`
      // (PaymentService.updatePaymentStatus / linkPaymentToChallenge) — never
      // `amount`. Require `amount` to be present AND unchanged on every update
      // so a user can neither lower NOR delete an authorized stake before the
      // admin-board off-session capture charges it (deleting it would make the
      // capture read NaN and skip the charge). updateData is a merge, so a legit
      // status/challengeId update keeps `amount` present and equal; every
      // payment doc is created with a non-optional amount.
      allow update: if request.auth != null
                    && ('amount' in request.resource.data)
                    && ('amount' in resource.data)
                    && request.resource.data.amount == resource.data.amount;
    }
    
    // ============================================================
    // WORKOUT SESSIONS
    // ============================================================
    
    match /workoutSessions/{sessionId} {
      // TEMPORARY: All operations allowed for authenticated users
      allow create, read, update, delete: if request.auth != null;
    }
    
    // ============================================================
    // GROUP CHALLENGES (Multiplayer 2-10 people)
    // ============================================================
    
    // Group hardening (mirrors the competitions pattern). Reads stay open —
    // the invite-code lookup runs before membership, and teammates render each
    // other's docs, so query rules can't be membership-scoped. Updates stay
    // open to any signed-in user because joins and progress syncs are
    // whole-roster transactional rewrites from clients (accepted residual
    // risk, same as competitions), but the group's identity and economic
    // template are pinned and deletion is restricted.
    function isGroupCreatorOrSoleParticipant(data) {
      return request.auth.uid == data.createdBy
        || (data.participants.size() == 1 && data.participants[0].id == request.auth.uid);
    }
    function parentGroupData(groupId) {
      return get(/databases/$(database)/documents/challengeGroups/$(groupId)).data;
    }

    match /challengeGroups/{groupId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.startDate is timestamp
        && request.resource.data.endDate is timestamp
        && request.resource.data.stakeAmount is number
        && request.resource.data.stakeAmount >= 0;

      // Live client writes (join, roster sync, workout counter) only touch
      // participants/totalMoneyStaked/totalWorkoutsCompleted, so these pins
      // cost nothing legitimate. isActive is server-owned (daily cleanup via
      // Admin SDK); pinning it stops clients resurrecting or hiding groups.
      // Timestamps compared at 1s tolerance: iOS round-trips
      // Timestamp → Date → Timestamp, which can drift by microseconds.
      allow update: if request.auth != null
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.inviteCode == resource.data.inviteCode
        && request.resource.data.isActive == resource.data.isActive
        && math.abs(request.resource.data.startDate.toMillis() - resource.data.startDate.toMillis()) < 1000
        && math.abs(request.resource.data.endDate.toMillis() - resource.data.endDate.toMillis()) < 1000
        && request.resource.data.stakeAmount == resource.data.stakeAmount
        && request.resource.data.get('mode', '') == resource.data.get('mode', '')
        && request.resource.data.get('durationDays', 0) == resource.data.get('durationDays', 0)
        && request.resource.data.get('startCalendarDateKey', '') == resource.data.get('startCalendarDateKey', '');

      // Creator deletes (create-flow rollback), or the sole remaining roster
      // entry (convert-to-solo / last-failure cleanup: the iOS manager prunes
      // expired/failed teammate rows before deleting, so the caller is the
      // only entry left). Honest caveat: with the update rule open for
      // whole-roster rewrites, a determined client can always rewrite the
      // roster to itself and then delete — this clause guards against
      // accidents, not a dedicated attacker (same accepted residual risk as
      // competitions).
      allow delete: if request.auth != null
        && isGroupCreatorOrSoleParticipant(resource.data);
    }

    // Per-day completion records. Writes are owner-scoped — every iOS write
    // path (updateProgress, backfillProgressDocs) touches only the signed-in
    // user's docs. Delete additionally allows the group's creator / sole
    // participant: deleteGroup batch-purges every participant's progress docs
    // (rules `get()` sees the pre-batch group doc even when the same batch
    // deletes it). Owner check first so the common case skips the get().
    match /groupProgress/{progressId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && (resource.data.userId == request.auth.uid
            || isGroupCreatorOrSoleParticipant(parentGroupData(resource.data.groupId)));
    }

    // In-progress HealthKit values for group running/steps previews.
    // Official completion remains in groupProgress. Owner-scoped writes —
    // update checks BOTH sides so a teammate can't take over an existing doc
    // (ids are predictable: groupId_userId_dayNumber) by stamping their own
    // uid into it.
    match /groupLiveProgress/{progressId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================
    // COMPETITIONS (Large-scale 10-10,000 people)
    // ============================================================
    
    // Competition creation is admin-only (product decision, v1). The client
    // DEBUG gate is cosmetic — this allowlist is the real guard. Seed once via
    // firebase-admin:  config/admins { adminUids: ["<uid>", …] }
    // Fail-closed: if the doc is missing, creation is denied for everyone.
    function isCompetitionAdmin() {
      return request.auth.uid in get(/databases/$(database)/documents/config/admins).data.adminUids;
    }

    match /competitions/{competitionId} {
      allow read: if request.auth != null;

      // Admin-only create. winnerBonusDpm drives a server-side DPM payout at
      // settlement (`cleanupStaleSocialChallenges`), so an open create rule
      // would let anyone mint DPM via a self-winning, already-expired
      // competition. The admin stamps the bonus at creation.
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid
        && isCompetitionAdmin()
        && request.resource.data.startDate is timestamp
        && request.resource.data.endDate is timestamp
        && request.resource.data.get('winnerBonusDpm', 0) is int
        && request.resource.data.get('winnerBonusDpm', 0) >= 0;

      // Joins, team creation, and progress sync are whole-doc transactional
      // rewrites from clients, so updates stay open to any signed-in user —
      // but the competition's identity and economic template are pinned, and
      // settled competitions are frozen (settlement fields are written only by
      // the cleanup function via Admin SDK, which bypasses these rules; a
      // client flipping status back to 'active' would replay the DPM payout).
      // Timestamps are compared at 1s tolerance: iOS round-trips
      // Timestamp → Date → Timestamp, which can drift by microseconds.
      // Accepted residual risk: any signed-in user can still rewrite teams[]
      // of a LIVE competition (inherent to the whole-doc transaction design);
      // settlement inputs must move server-side if bonuses grow material.
      allow update: if request.auth != null
        && !('settledAt' in resource.data)
        && !('settledAt' in request.resource.data)
        && request.resource.data.get('winningTeamId', null) == null
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.inviteCode == resource.data.inviteCode
        && math.abs(request.resource.data.startDate.toMillis() - resource.data.startDate.toMillis()) < 1000
        && math.abs(request.resource.data.endDate.toMillis() - resource.data.endDate.toMillis()) < 1000
        && request.resource.data.stakeAmount == resource.data.stakeAmount
        && request.resource.data.get('winnerBonusDpm', 0) == resource.data.get('winnerBonusDpm', 0);

      // Only the organizer can delete, and only before settlement — a settled
      // competition is a payout record and stays (archived copy also exists).
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy
        && !('settledAt' in resource.data);
    }

    // Admin allowlist for competition creation — server-managed only.
    match /config/admins {
      allow read, write: if false;
    }
    
    // ============================================================
    // ARCHIVE COLLECTIONS (Completed/Failed challenges storage)
    // ============================================================
    
    // Archived challenges
    match /archivedChallenges/{archiveId} {
      // TEMPORARY: All operations allowed for authenticated users
      allow create, read: if request.auth != null;
      allow update, delete: if false;
    }
    
    // Archived groups - any authenticated user can archive/read
    // Security: Archives are immutable once created, and contain historical data
    match /archivedChallengeGroups/{archiveId} {
      // Anyone can create archives (triggered when group ends)
      allow create: if request.auth != null;
      
      // Anyone authenticated can read archives (for viewing historical challenges)
      allow read: if request.auth != null;
      
      // No updates or deletes - archives are immutable
      allow update, delete: if false;
    }
    
    // Archived competitions
    match /archivedCompetitions/{archiveId} {
      allow create: if request.auth != null && (
        // Creator can archive
        request.auth.uid == request.resource.data.createdBy ||
        // Allow authenticated users (cloud function also archives)
        true
      );
      
      // Anyone authenticated can read archived competitions
      allow read: if request.auth != null;
      
      // No updates or deletes - archives are immutable
      allow update, delete: if false;
    }
    
    // Archived group progress
    match /archivedGroupProgress/{archiveId} {
      allow create: if request.auth != null;
      
      allow read: if request.auth != null;
      
      // No updates or deletes - archives are immutable
      allow update, delete: if false;
    }
    
    // ============================================================
    // BADGE SYSTEM
    // ============================================================
    
    // Badge progress (lowercase - matches code)
    match /badgeProgress/{userId} {
      // TEMPORARY: All operations allowed for authenticated users
      allow create, read, update, delete: if request.auth != null;
    }
    
    // User badges collection
    match /userBadges/{userId} {
      // TEMPORARY: All operations allowed for authenticated users
      allow create, read, update, delete: if request.auth != null;
    }
    
    // ============================================================
    // FLAMES & SPARKS (Social engagement — server-authoritative)
    //
    // referrals: audit log of spark <-> flame links (written by trigger).
    // sparkDailyDigest: per-spark per-day aggregator for batched push.
    // flameEvents: audit log of credit/link/cap events.
    //
    // All three are written exclusively by Cloud Functions (admin SDK).
    // Clients can only READ rows that pertain to them.
    // ============================================================

    match /referrals/{referralId} {
      allow read: if request.auth != null
                  && (resource.data.sparkId == request.auth.uid
                      || resource.data.flameId == request.auth.uid);
      allow write: if false; // server-only via admin SDK
    }

    match /sparkDailyDigest/{digestId} {
      allow read: if request.auth != null
                  && resource.data.sparkId == request.auth.uid;
      allow write: if false; // server-only
    }

    match /flameEvents/{eventId} {
      allow read: if request.auth != null
                  && (resource.data.sparkId == request.auth.uid
                      || resource.data.flameId == request.auth.uid);
      allow write: if false; // server-only
    }
    
    // ============================================================
    // GLOBAL DATA (Read-only for clients)
    // ============================================================
    
    match /globalStats/{docId} {
      // TEMPORARY: Allow read without auth for development
      allow read: if true;
      allow write: if false; // Cloud Function only
    }

    // `globalStats/userCounter` is the atomic counter used by
    // UserManager.getNextUserNumberAtomic() to assign sequential "UserNNN"
    // names on first sign-in. The transaction reads + writes this single doc
    // directly from the iOS client — without this rule, every new user
    // sign-in fails with PERMISSION_DENIED before the user doc is ever
    // created. The generic globalStats deny above still applies to every
    // other doc in the collection (badgeStats, etc.).
    //
    // FOLLOW-UP: move the counter into a callable Cloud Function so this
    // single client-writable surface goes away.
    match /globalStats/userCounter {
      allow read, write: if request.auth != null;
    }

    match /globalStats/{docId}/{subcollection}/{subDocId} {
      allow read: if true;
      allow write: if false; // Cloud Function only
    }

    match /leaderboards/{leagueId} {
      allow read: if true;
      allow write: if false; // Cloud Function only
    }

    // ============================================================
    // VOUCHER CODE STATS (aggregate counters per code)
    // Written exclusively by the redeemVoucherCode Cloud Function via the
    // Admin SDK. Clients must never read this — exposing redemption counts
    // would leak distribution telemetry for an exclusive code.
    // (This rule precedes the catch-all so it is honored.)
    // ============================================================

    match /voucherCodes/{code} {
      allow read, write: if false;
    }

    // ============================================================
    // USER NOTICES (Support / system messages targeted at one user)
    // Created by Cloud Functions; the website lists them filtered by
    // userId == auth.uid. Explicit rule placed before the catch-all so
    // it's still honoured if/when the catch-all is removed.
    // ============================================================

    match /userNotices/{noticeId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if false;
      allow update: if request.auth != null &&
                       resource.data.userId == request.auth.uid &&
                       request.resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    // ============================================================
    // ADMIN AUDIT LOG (Cloud Function only — Apple token revocations, etc.)
    // ============================================================

    match /adminActions/{actionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // server-only
    }

    // ============================================================
    // CHALLENGE DISPUTES (Failed-challenge appeals)
    // ============================================================

    match /challengeDisputes/{challengeId} {
      allow read, create, update: if request.auth != null;
      allow delete: if false;
    }

    // ============================================================
    // (No catch-all — anything not explicitly allowed is denied.)
    // Field-level write restrictions on /users above only take effect when
    // they aren't shadowed by a permissive catch-all rule.
    // ============================================================
  }
}
